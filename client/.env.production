# Colyseus server URL baked into the client at BUILD time.
# Set this to your deployed Railway SERVER service's public domain.
# Must use wss:// (secure WebSocket) because the client is served over https://.
#
# Example:
#   VITE_SERVER_URL=wss://bedwars-server-production.up.railway.app
#
# You can set this here (committed) OR as a Build Variable on the Railway
# CLIENT service (dashboard > Variables). A real shell/build env var takes
# precedence over this file, so Railway build variables win.
VITE_SERVER_URL=wss://bedwars-server.onrender.com

