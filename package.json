{
  "name": "bedwars",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "shared",
    "server",
    "client"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev:server": "npm --workspace @bedwars/server run dev",
    "dev:client": "npm --workspace @bedwars/client run dev",
    "build": "npm --workspace @bedwars/client run build",
    "build:client": "npm --workspace @bedwars/client run build",
    "start": "serve -s client/dist",
    "start:client": "serve -s client/dist",
    "start:server": "npm --workspace @bedwars/server run start"
  },
  "dependencies": {
    "serve": "^14.2.6"
  }
}
